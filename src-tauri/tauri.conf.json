{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Applications and Firms Viewer",
  "version": "0.5.1",
  "identifier": "uk.co.dwgsoftware.appsfirmsviewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Applications and Firms Viewer",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
